<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Manglani General Store</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<style>
* {margin:0; padding:0; box-sizing:border-box; font-family:Poppins;}

body {background:#f5f7fb;}

header {
  background:#2b7a78;
  color:#fff;
  text-align:center;
  padding:15px;
}

header h1 {font-size:22px;}
header p {font-size:14px;}

.filters {
  display:flex;
  overflow:auto;
  gap:10px;
  padding:10px;
}

.filters button {
  padding:8px 12px;
  border:none;
  border-radius:20px;
  background:#ddd;
  cursor:pointer;
}

.filters button.active {background:#2b7a78; color:#fff;}

.products {
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:10px;
  padding:10px;
}

.card {
  background:#fff;
  border-radius:10px;
  padding:10px;
  box-shadow:0 2px 5px rgba(0,0,0,0.1);
}

.card img {
  width:100%;
  height:120px;
  object-fit:cover;
  border-radius:8px;
}

.card h4 {font-size:14px;}
.card p {font-size:12px; color:#555;}
.price {font-weight:600;}

.card button {
  margin-top:5px;
  width:100%;
  padding:6px;
  border:none;
  border-radius:5px;
  background:#3aafa9;
  color:#fff;
  cursor:pointer;
}

/* Cart */
.cart-btn {
  position:fixed;
  bottom:20px;
  right:20px;
  background:#ff5722;
  color:#fff;
  padding:12px;
  border-radius:50%;
  font-size:18px;
  cursor:pointer;
}

.cart-count {
  position:absolute;
  top:-5px;
  right:-5px;
  background:black;
  color:#fff;
  border-radius:50%;
  padding:3px 6px;
  font-size:12px;
}

.cart {
  position:fixed;
  top:0;
  right:-100%;
  width:100%;
  height:100%;
  background:#fff;
  transition:0.3s;
  overflow:auto;
  padding:15px;
}

.cart.active {right:0;}

.cart-item {
  display:flex;
  justify-content:space-between;
  margin-bottom:10px;
}

.cart-item button {padding:2px 6px;}

.total {font-weight:bold; margin:10px 0;}

form input, form textarea {
  width:100%;
  margin-bottom:10px;
  padding:8px;
}

form button {
  width:100%;
  padding:10px;
  background:#2b7a78;
  color:#fff;
  border:none;
}

/* WhatsApp */
.whatsapp {
  position:fixed;
  bottom:20px;
  left:20px;
  background:#25D366;
  color:#fff;
  padding:10px;
  border-radius:50%;
  text-decoration:none;
}
</style>
</head>

<body>

<header>
<h1>Manglani General Store</h1>
<p>The complete shop</p>
</header>

<div class="filters">
<button onclick="filter('All')" class="active">All</button>
<button onclick="filter('Groceries')">Groceries</button>
<button onclick="filter('Snacks')">Snacks</button>
</div>

<div class="products" id="products"></div>

<!-- CART BUTTON -->
<div class="cart-btn" onclick="toggleCart()">
🛒 <span class="cart-count" id="count">0</span>
</div>

<!-- CART -->
<div class="cart" id="cart">
<h2>Your Cart</h2>
<div id="cartItems"></div>
<div class="total" id="total"></div>

<form action="https://formspree.io/f/mrejbrop" method="POST" onsubmit="prepareOrder()">
<input type="text" name="name" placeholder="Your Name" required>
<input type="tel" name="phone" placeholder="Phone Number" required>
<textarea name="address" placeholder="Delivery Address" required></textarea>
<textarea name="notes" placeholder="Instructions"></textarea>

<input type="hidden" name="order" id="orderData">

<button type="submit">Place Order</button>
</form>
</div>

<a class="whatsapp" href="https://wa.me/7879117042" target="_blank">💬</a>

<script>
let products = [
{name:"Aashirvaad Atta 5kg", price:280, cat:"Groceries", img:"https://via.placeholder.com/300", desc:"Premium wheat flour"},
{name:"Rice 1kg", price:60, cat:"Groceries", img:"https://via.placeholder.com/300", desc:"Fresh rice"},
{name:"Sugar 1kg", price:45, cat:"Groceries", img:"https://via.placeholder.com/300", desc:"Refined sugar"},
{name:"Salt", price:20, cat:"Groceries", img:"https://via.placeholder.com/300", desc:"Iodized salt"},
{name:"Maggi Pack", price:14, cat:"Snacks", img:"https://via.placeholder.com/300", desc:"Instant noodles"},
{name:"Lays Chips", price:20, cat:"Snacks", img:"https://via.placeholder.com/300", desc:"Crunchy chips"},
{name:"Biscuits", price:30, cat:"Snacks", img:"https://via.placeholder.com/300", desc:"Tea biscuits"},
{name:"Cold Drink", price:40, cat:"Snacks", img:"https://via.placeholder.com/300", desc:"Refreshing drink"}
];

let cart = JSON.parse(localStorage.getItem("cart")) || [];

function renderProducts(list){
let html="";
list.forEach((p,i)=>{
html+=`
<div class="card">
<img src="${p.img}" loading="lazy" alt="${p.name}">
<h4>${p.name}</h4>
<p>${p.desc}</p>
<div class="price">₹${p.price}</div>
<button onclick="addToCart(${i})">Add</button>
</div>`;
});
document.getElementById("products").innerHTML=html;
}

function filter(cat){
document.querySelectorAll(".filters button").forEach(b=>b.classList.remove("active"));
event.target.classList.add("active");

if(cat==="All") renderProducts(products);
else renderProducts(products.filter(p=>p.cat===cat));
}

function addToCart(i){
let item=products[i];
let found=cart.find(c=>c.name===item.name);
if(found) found.qty++;
else cart.push({...item, qty:1});
updateCart();
}

function updateCart(){
localStorage.setItem("cart", JSON.stringify(cart));

document.getElementById("count").innerText=cart.length;

let html="", total=0;

cart.forEach((c,i)=>{
let sub=c.price*c.qty;
total+=sub;

html+=`
<div class="cart-item">
<div>${c.name} (₹${c.price})</div>
<div>
<button onclick="changeQty(${i},-1)">-</button>
${c.qty}
<button onclick="changeQty(${i},1)">+</button>
<button onclick="removeItem(${i})">x</button>
</div>
</div>`;
});

document.getElementById("cartItems").innerHTML=html;
document.getElementById("total").innerText="Total: ₹"+total;
}

function changeQty(i,delta){
cart[i].qty+=delta;
if(cart[i].qty<=0) cart.splice(i,1);
updateCart();
}

function removeItem(i){
cart.splice(i,1);
updateCart();
}

function toggleCart(){
document.getElementById("cart").classList.toggle("active");
}

function prepareOrder(){
let text="";
let total=0;

cart.forEach(c=>{
let sub=c.price*c.qty;
total+=sub;
text+=`${c.name} x${c.qty} = ₹${sub}\n`;
});

text+=`\nTotal: ₹${total}`;

document.getElementById("orderData").value=text;

cart=[];
localStorage.removeItem("cart");

setTimeout(()=>{
alert("Order placed! Manglani General Stores will contact you on WhatsApp.");
},500);
}

renderProducts(products);
updateCart();
</script>

</body>
</html>
