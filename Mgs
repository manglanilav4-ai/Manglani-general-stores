<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Manglani General Store</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<style>
body {
  font-family: 'Poppins', sans-serif;
  margin: 0;
  background: #f5f5f5;
}

header {
  background: #2e7d32;
  color: white;
  text-align: center;
  padding: 20px;
}

.products {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px,1fr));
  gap: 15px;
  padding: 20px;
}

.card {
  background: white;
  padding: 10px;
  border-radius: 10px;
  text-align: center;
}

.card img {
  width: 100%;
  border-radius: 10px;
}

button {
  background: #2e7d32;
  color: white;
  border: none;
  padding: 10px;
  margin-top: 10px;
  width: 100%;
  border-radius: 5px;
}

form {
  background: white;
  padding: 20px;
  margin: 20px;
  border-radius: 10px;
}

input, textarea {
  width: 100%;
  padding: 10px;
  margin-top: 10px;
}
</style>
</head>

<body>

<header>
  <h1>Manglani General Store</h1>
  <p>The Complete Shop</p>
</header>

<section class="products">

  <div class="card">
    <img src="https://i.ibb.co/mVG1dsYj/17777034790544190107798749411598.jpg">
    <h3>Daily Grocery Pack</h3>
    <button onclick="order('Daily Grocery Pack')">Order Now</button>
  </div>

  <div class="card">
    <img src="https://via.placeholder.com/200">
    <h3>Plastic Items</h3>
    <button onclick="order('Plastic Items')">Order Now</button>
  </div>

</section>

<form action="https://formspree.io/f/mrejbrop" method="POST">
  <h2>Place Order</h2>
  <input type="text" name="name" placeholder="Your Name" required>
  <input type="text" name="phone" placeholder="Phone Number" required>
  <input type="text" name="product" id="product">
  <textarea name="address" placeholder="Address" required></textarea>
  <button type="submit">Submit Order</button>
</form>

<script>
function order(product){
  document.getElementById("product").value = product;
  window.scrollTo(0, document.body.scrollHeight);
}
</script>

</body>
</html>
